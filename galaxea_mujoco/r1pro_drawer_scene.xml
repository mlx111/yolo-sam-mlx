<mujoco model="r1pro_drawer_scene">
  <include file="model.xml"/>
  <option timestep="0.005" impratio="10" integrator="implicitfast" cone="elliptic" solver="PGS"/>

  <asset>
    <mesh name="drawer_handle_mesh" file="../stl/doorknob.stl" scale="0.45 0.45 0.45"/>
    <mesh name="inside_phone_mesh" file="../stl/phone.stl"/>
  </asset>

  <worldbody>
    <light name="drawer_scene_key_light" pos="0 0 3" dir="0 0 -1" diffuse="0.7 0.7 0.7"/>

    <geom name="drawer_floor" type="box" pos="0.28 0.00 0.715" size="0.45 0.38 0.025"
          rgba="0.48 0.43 0.36 1" condim="3" friction="1.0 0.02 0.002"
          priority="1" solref="0.004 1" solimp="0.95 0.99 0.001"/>

    <body name="cabinet_body" pos="0.42 0.00 0.92">
      <geom name="cabinet_back_wall_geom" type="box" pos="0.16 0.00 0.08" size="0.025 0.24 0.18"
            rgba="0.36 0.33 0.29 1" condim="3" friction="1.0 0.02 0.002"/>
      <geom name="cabinet_left_wall_geom" type="box" pos="0.00 0.25 0.08" size="0.18 0.025 0.18"
            rgba="0.36 0.33 0.29 1" condim="3" friction="1.0 0.02 0.002"/>
      <geom name="cabinet_right_wall_geom" type="box" pos="0.00 -0.25 0.08" size="0.18 0.025 0.18"
            rgba="0.36 0.33 0.29 1" condim="3" friction="1.0 0.02 0.002"/>
      <geom name="cabinet_bottom_geom" type="box" pos="0.00 0.00 -0.11" size="0.20 0.26 0.025"
            rgba="0.30 0.28 0.25 1" condim="3" friction="1.0 0.02 0.002"/>
      <geom name="cabinet_top_geom" type="box" pos="0.00 0.00 0.27" size="0.20 0.26 0.025"
            rgba="0.30 0.28 0.25 1" condim="3" friction="1.0 0.02 0.002"/>

      <body name="drawer_body" pos="-0.08 0.00 0.02">
        <joint name="drawer_slide_joint" type="slide" axis="-1 0 0" range="0 0.32" damping="8" actuatorfrcrange="-120 120"/>
        <geom name="drawer_tray_geom" type="box" pos="0.00 0.00 0.00" size="0.16 0.20 0.025"
              rgba="0.64 0.58 0.48 1" condim="3" friction="1.0 0.02 0.002"/>
        <geom name="drawer_left_wall_geom" type="box" pos="0.00 0.21 0.07" size="0.16 0.015 0.07"
              rgba="0.58 0.52 0.44 1" condim="3" friction="1.0 0.02 0.002"/>
        <geom name="drawer_right_wall_geom" type="box" pos="0.00 -0.21 0.07" size="0.16 0.015 0.07"
              rgba="0.58 0.52 0.44 1" condim="3" friction="1.0 0.02 0.002"/>
        <geom name="drawer_front_panel_geom" type="box" pos="-0.17 0.00 0.08" size="0.025 0.23 0.11"
              rgba="0.50 0.43 0.35 1" condim="3" friction="1.0 0.02 0.002"/>
        <geom name="drawer_front_edge_geom" type="box" pos="-0.17 0.00 0.18" size="0.027 0.22 0.012"
              rgba="0.42 0.36 0.30 1" condim="3" friction="1.0 0.02 0.002"/>
        <geom name="drawer_handle_collision_geom" type="box" pos="-0.205 0.00 0.09" size="0.018 0.06 0.025"
              rgba="0.08 0.08 0.08 0.2" condim="3" friction="1.5 0.02 0.002"/>
        <geom name="drawer_handle_visual_geom" type="mesh" pos="-0.235 0.00 0.09" quat="0.70710678 0 0.70710678 0"
              mesh="drawer_handle_mesh" contype="0" conaffinity="0" group="1" rgba="0.12 0.12 0.12 1"/>
        <site name="handle_site" pos="-0.235 0.00 0.09" size="0.015" rgba="1 0.2 0.1 1"/>
        <site name="drawer_inside_site" pos="-0.02 0.00 0.12" size="0.015" rgba="0.1 0.8 1 1"/>
        <site name="drawer_open_site" pos="-0.32 0.00 0.09" size="0.015" rgba="0.2 1 0.2 1"/>
      </body>
    </body>

    <body name="inside_target_object" pos="0.32 0.02 1.045">
      <freejoint name="inside_target_freejoint"/>
      <geom name="inside_target_collision_geom" type="box" pos="0 0 0" size="0.075 0.013 0.025"
            mass="0.035" condim="6" friction="2.0 0.2 0.002" rgba="0.1 0.4 0.9 0.35"/>
      <geom name="inside_target_visual_geom" type="mesh" pos="0 0 0" mesh="inside_phone_mesh"
            contype="0" conaffinity="0" group="1" rgba="0.05 0.08 0.12 1"/>
      <site name="inside_target_site" pos="0 0 0" size="0.012" rgba="1 0.9 0.1 1"/>
    </body>
  </worldbody>

  <actuator>
    <general name="drawer_slide_joint_pos" joint="drawer_slide_joint"
             gaintype="fixed" biastype="affine" gainprm="900" biasprm="0 -900 -80"
             ctrllimited="true" ctrlrange="0 0.32" forcelimited="true" forcerange="-120 120"/>
  </actuator>
</mujoco>
